# Walrus network environment: mainnet | testnet | devnet
WALRUS_NETWORK=testnet

# Custom endpoints (optional; takes precedence over WALRUS_NETWORK)
# Testnet defaults (public, no auth):
#   publisher: https://publisher.walrus-testnet.walrus.space
#   aggregator: https://aggregator.walrus-testnet.walrus.space
# WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Default upload storage duration (epochs)
WALRUS_EPOCHS=5

# ==========================================
# Mainnet-only configuration (can be ignored on Testnet)
# ==========================================

# [Strategy 1] Self-hosted Publisher: specify your private endpoint
# WALRUS_PUBLISHER_URL=https://publisher.your-domain.com

# [Strategy 2] Upload Relay: API Key authentication
# WALRUS_RELAY_API_KEY=your-relay-api-key
# WALRUS_RELAY_AUTH_HEADER=X-API-Key

# [Strategy 3] On-chain signing: Sui wallet private key
# Export from Sui CLI: sui keytool export
# Format: suiprivkey1q... or 0x... or base64
# WALRUS_SUI_PRIVATE_KEY=suiprivkey1q...

# Sui RPC endpoint (for balance queries; optional)
# WALRUS_SUI_RPC_URL=https://fullnode.mainnet.sui.io:443