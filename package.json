{
  "name": "walgent",
  "version": "0.1.0",
  "description": "Walgent — Decentralized storage for AI agents. Let your agents store outputs on Walrus.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "walgent": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx tests/**/*.test.ts",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "walrus",
    "agent",
    "skill",
    "storage",
    "decentralized",
    "sui",
    "web3",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}